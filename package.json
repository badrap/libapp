{
  "name": "@badrap/libapp",
  "version": "0.10.3",
  "description": "TypeScript helpers for creating Badrap apps",
  "homepage": "https://github.com/badrap/libapp#readme",
  "bugs": {
    "url": "https://github.com/badrap/libapp/issues"
  },
  "license": "MIT",
  "author": "Joachim Viide <jviide@iki.fi>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/badrap/libapp.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    "./api": "./dist/api/index.js",
    "./ui": "./dist/ui/index.js",
    "./ui/experimental": "./dist/ui/experimental/index.js",
    "./jsx-runtime": "./dist/jsx-runtime.js",
    "./jsx-dev-runtime": "./dist/jsx-dev-runtime.js"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "fix": "oxfmt && oxlint --fix",
    "check": "oxfmt --check && oxlint",
    "build": "rm -rf dist/* && tsc",
    "changeset": "changeset",
    "bump": "changeset version",
    "tag": "changeset tag"
  },
  "dependencies": {
    "@badrap/valita": "^0.4.6"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
